# Copy to .env and fill in real values for local dev. Never commit .env.

# --- Postgres ---
# Host port defaults to 55432 (not 5432) to avoid clashing with a locally installed Postgres.
POSTGRES_USER=agent_factory
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agent_factory
POSTGRES_PORT=55432

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible artifact storage) ---
MINIO_ROOT_USER=agent_factory
MINIO_ROOT_PASSWORD=change-me-too
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API service ---
# DATABASE_URL below is the HOST-side connection string (used by Makefile targets like
# `make migrate` and by local pytest integration runs). The `api` container itself talks to
# postgres/redis/minio over the docker-compose network and gets its own DATABASE_URL /
# REDIS_URL / S3_ENDPOINT_URL built from the vars above in docker-compose.yml.
API_PORT=8000
DATABASE_URL=postgresql+psycopg://agent_factory:change-me@localhost:55432/agent_factory
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=agent_factory
S3_SECRET_KEY=change-me-too

# --- Web service ---
WEB_PORT=5173
VITE_API_URL=http://localhost:8000

# --- Auth (OIDC SSO, wired up in T-008) ---
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- LLM (Anthropic API) ---
ANTHROPIC_API_KEY=

# --- Observability (Langfuse, wired up later) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
