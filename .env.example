# Copy to .env and fill in real values for local dev. Never commit .env.

# --- Postgres ---
# Host port defaults to 55432 (not 5432) to avoid clashing with a locally installed Postgres.
POSTGRES_USER=agent_factory
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agent_factory
POSTGRES_PORT=55432

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible artifact storage) ---
MINIO_ROOT_USER=agent_factory
MINIO_ROOT_PASSWORD=change-me-too
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API service ---
# DATABASE_URL below is the HOST-side connection string (used by Makefile targets like
# `make migrate` and by local pytest integration runs). The `api` container itself talks to
# postgres/redis/minio over the docker-compose network and gets its own DATABASE_URL /
# REDIS_URL / S3_ENDPOINT_URL built from the vars above in docker-compose.yml.
API_PORT=8000
DATABASE_URL=postgresql+psycopg://agent_factory:change-me@localhost:55432/agent_factory
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=agent_factory
S3_SECRET_KEY=change-me-too

# --- Web service ---
WEB_PORT=5173
VITE_API_URL=http://localhost:8000

# --- CI webhook (SPEC-005) ---
# HMAC-SHA256 shared secret between the agent-pr-gate GitHub Actions workflow and
# POST /webhooks/ci-result. Empty disables signature verification (local/dev only).
CI_WEBHOOK_SECRET=

# --- Auth (OIDC SSO, SPEC-006) ---
# Google: OIDC_ISSUER_URL=https://accounts.google.com, client id/secret from a Google
# Cloud OAuth client. Login is 501 until all three are set.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
WEB_LOGIN_SUCCESS_URL=http://localhost:5173
# HS256 secret for our own session JWTs (not sent to the IdP). 32+ random bytes.
SESSION_JWT_SECRET=
# Shared secret for machine callers (apps/orchestrator, apps/sandbox) — sent as
# `Authorization: Bearer <token>` in place of a human session.
AGENT_FACTORY_SERVICE_TOKEN=
# Comma-separated emails auto-promoted to admin on first login (pilot bootstrap).
ADMIN_EMAILS=
# Enables POST /auth/dev-login (mint a session token without a real OIDC round-trip).
# Local/CI only — never set this in a deployed environment.
AUTH_DEV_MODE=false

# --- LLM (Anthropic API) ---
# Platform-billed key: eval-gate CI and any call with no org BYOK key configured yet.
ANTHROPIC_API_KEY=

# --- Vault (BYOK provider keys, T-202/SPEC-202) ---
# Dev-mode Vault (docker-compose) — in-memory, unsealed on boot, root-token auth. Real
# production Vault (raft storage, auto-unseal, AppRole auth) is out of scope for T-202.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_PORT=8200
# Root token id the vault container mints itself with on boot (dev-mode only).
VAULT_DEV_ROOT_TOKEN=dev-root-token

# --- GitHub (T-009 pilot runner + dev agent's `gh pr create`) ---
# Fine-grained PAT or classic token with repo scope. `gh` auto-authenticates
# non-interactively from this env var — no `gh auth login` browser flow needed. Used as
# the fallback for tickets with no repo_id (T-203's dogfood path, unchanged).
GITHUB_TOKEN=

# --- GitHub App (repo connect/provision, T-203/SPEC-203) ---
# No live App is registered in this environment — see docs/06-tech-stack.md's
# implementation-status note. The App's own private key is NOT an env var; it lives in
# Vault at platform/github/app-private-key (seed locally/CI via
# scripts/seed_github_app_key.py).
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
# The platform's own installation (used only for repos it provisions under its own org
# from GITHUB_APP_TEMPLATE_REPO — never for a customer's connected repo).
GITHUB_APP_PLATFORM_INSTALLATION_ID=
GITHUB_APP_TEMPLATE_REPO=
WEB_REPOS_SUCCESS_URL=http://localhost:5173

# --- Observability (Langfuse Cloud - T-101 eval harness; see docs/06-tech-stack.md) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
